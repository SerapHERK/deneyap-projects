tate  # BERT'in tüm zaman adımlarındaki çıktıları\n","        gru_output, _ = self.gru(hidden_states)  # GRU'dan geçirme\n","        pooled_output = torch.mean(gru_output, dim=1)  # Ortalama alarak sabit boyutlu bir çıktı oluşturuyoruz\n","        weight_pred = self.fc(pooled_output)  # Regresyon için çıktı\n","        return weight_pred\n","\n","# Veri yükleme ve model eğitimi\n","def main():\n","    # Örnek veri kümesi\n","    data = {\n","        \"protein_sequence\": [\"MKTFFVLLLAAAVALAMA\", \"AGTTVLLDCAAARAV\", \"MKTFLLLLAA\", \"AGLVVVLC\"],\n","        \"weight\": [15.5, 12.7, 8.3, 10.1]\n","    }\n","    df = pd.DataFrame(data)\n","\n","    # Eğitim ve test setine ayırma\n","    train_df, test_df = train_test_split(df, test_size=0.2, random_state=42)\n","\n","    # Tokenizer ve ProteinBERT modelini yükleme\n","    model_name = \"Rostlab/prot_bert\"\n","    tokenizer = BertTokenizer.from_pretrained(model_name)\n","    bert_model = BertModel.from_pretrained(model_name)\n","\n","    # Dataset ve DataLoader\n","    train_dataset = ProteinDataset(train_df[\"protein_sequence\"].tolist(), train_df[\"weight\"].tolist(), tokenizer)\n","    test_dataset = ProteinDataset(test_df[\"protein_sequence\"].tolist(), test_df[\"weight\"].tolist(), tokenizer)\n","\n","    train_loader = DataLoader(train_dataset, batch_size=2, shuffle=True)\n","    test_loader = DataLoader(test_dataset, batch_size=2)\n","\n","    # Model, optimizer ve kayıp fonksiyonu\n","    device = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n","    model = ProteinWeightPredictorGRU(bert_model).to(device)\n","\n","    optimizer = torch.optim.Adam(model.parameters(), lr=1e-4)\n","    criterion = nn.MSELoss()\n","\n","    # Model eğitimi\n","    num_epochs = 5\n","    for epoch in range(num_epochs):\n","        model.train()\n","        total_loss = 0\n","        for batch in train_loader:\n","            input_ids = batch[\"input_ids\"].to(device)\n","            attention_mask = batch[\"at