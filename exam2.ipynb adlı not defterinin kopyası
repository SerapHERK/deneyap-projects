orch\n","import torch.nn as nn\n","from transformers import BertTokenizer, BertModel\n","import pandas as pd\n","from torch.utils.data import DataLoader, Dataset\n","from sklearn.model_selection import train_test_split\n","import numpy as np\n","\n","# 1. Protein Dataset Tanımlama\n","class ProteinDataset(Dataset):\n","    def __init__(self, sequences, weights, tokenizer, max_length=512):\n","        self.sequences = sequences\n","        self.weights = weights\n","        self.tokenizer = tokenizer\n","        self.max_length = max_length\n","\n","    def __len__(self):\n","        return len(self.sequences)\n","\n","    def __getitem__(self, idx):\n","        sequence = self.sequences[idx]\n","        weight = self.weights[idx]\n","        inputs = self.tokenizer(sequence, return_tensors=\"pt\", max_length=self.max_length, padding=\"max_length\", truncation=True)\n","        return {\n","            \"input_ids\": inputs[\"input_ids\"].squeeze(0),\n","            \"attention_mask\": inputs[\"attention_mask\"].squeeze(0),\n","            \"weight\": torch.tensor(weight, dtype=torch.float)\n","        }\n","\n","# 2. Model Tanımı (GRU ile iyileştirme)\n","class ProteinWeightPredictor(nn.Module):\n","    def __init__(self, bert_model):\n","        super(ProteinWeightPredictor, self).__init__()\n","        self.bert = bert_model\n","        self.gru = nn.GRU(\n","            input_size=bert_model.config.hidden_size,\n","            hidden_size=1024,  # Gizli katman boyutunu artırdık\n","            num_layers=4,  # Daha fazla GRU katmanı ekledik\n","            batch_first=True,\n","            bidirectional=True\n","        )\n","        self.regressor = nn.Linear(1024 * 2, 1)  # Bidirectional olduğu için gizli katman boyutunu iki katına çıkardık\n","\n","    def forward(self, input_ids, attention_mask):\n","        outputs = self.bert(input_ids=input_ids, attention_mask=attention_mask)\n","        pooled_output = outputs.pooler_output  # [CLS] token'ın gömme çıktısı\n","        gru_output, _ = self.gru(pooled_output.unsqueeze(1))  # GRU'ya input veriyoruz\n","        weight_pred = self.regressor(gru_output[:, -1, :])  # Son katmandan çıktı alıyoruz\n","        return weight_pred\n","\n","# 3. Veriyi Yükleme ve Hazırlama\n","# Örnek veri\n","data = {\n","    \"protein_sequence\": [\"MKTFFVLLLAAAVALAMA\", \"AGTTVLLDCAAARAV\", \"MKTFLLLLAA\", \"AGLVVVLC\"],\n","    \"weight\": [15.5, 12.7, 8.3, 10.1]\n","}\n","df = pd.DataFrame(data)\n","\n","# Eğitim ve test ayrımı\n","train_df, test_df = train_test_split(df, test_size=0.2, random_state=42)\n","\n","# Tokenizer ve model yüklemesi\n","model_name = \"Rostlab/prot_bert\"\n","tokenizer = BertTokenizer.from_pretrained(model_name)\n","bert_model = BertModel.from_pretrained(model_name)\n","\n","# Dataset ve DataLoader\n","train_dataset = ProteinDataset(train_df[\"protein_sequence\"].tolist(), train_df[\"weight\"].tolist(), tokenizer)\n","test_dataset = ProteinDataset(test_df[\"protein_sequence\"].tolist(), test_df[\"weight\"].tolist(), tokenizer)\n","\n","train_loader = DataLoader(train_dataset, batch_size=2, shuffle=True)\n","test_loader = DataLoader(test_dataset, batch_size=2)\n","\n","# 4. Eğitim Ayarları\n","device = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n","model = ProteinWeightPredictor(bert_model).to(device)\n","\n","# Optimizer ve Huber Kayıp Fonksiyonu\n","optimizer = torch.optim.AdamW(model.parameters(), lr=1e-4)  # Öğrenme oranını artırdık\n","criterion = nn.HuberLoss(delta=1.0)  # Huber kayıp fonksiyonunu kullandık\n","\n","# 5. Eğitim Döngüsü\n","num_epochs = 50\n","for epoch in range(num_epochs):\n","    model.train()\n","    total_loss = 0\n","    for batch in train_loader:\n","        input_ids = batch[\"input_ids\"].to(device)\n","        attention_mask = batch[\"attention_mask\"].to(device)\n","        weights = batch[\"weight\"].to(device)\n","\n","        optimizer.zero_grad()\n","        predictions = model(input_ids, attention_mask)\n","        loss = criterion(predictions.squeeze(-1), weights)\n","        loss.backward()\n","        optimizer.step()\n","\n","        total_loss += loss.item()\n","    print(f\"Epoch {epoch+1}/{num_epochs}, Loss: {total_loss / len(train_loader)}\")\n","\n","# 6. Test Edinme\n","model.eval()\n","predictions = []\n","actuals = []\n","\n","with torch.no_grad():\n","    for batch in test_loader:\n","        input_ids = batch[\"input_ids\"].to(device)\n","        attention_mask = batch[\"attention_mask\"].to(device)\n","        weights = batch[\"weight\"].to(device)\n","\n","        outputs = model(input_ids, attention_mask)\n","        predictions.extend(outputs.squeeze(-1).cpu().numpy())\n","        actuals.extend(weights.cpu().numpy())\n","\n","# Sonuçların Gösterilmesi\n","result_df = pd.DataFrame({\"Actual\": actuals, \"Predicted\": predictions})\n","print(result_df)\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":436},"id":"hzO7Q0yqjqgV","outputId":"c496fe51-3c6f-4ce5-9974-3806da02d079","executionInfo":{"status":"error","timestamp":1748000138861,"user_tz":-180,"elapsed":9612,"user":{"displayName":"Serap HERKİLOĞLU","userId":"11894322177940657790"}}},"execution_count":14,"outputs":[{"output_type":"error","ename":"OutOfMemoryError","evalue":"CUDA out of memory. Tried to allocate 158.00 MiB. GPU 0 has a total capacity of 14.74 GiB of which 2.12 MiB is free. Process 2498 has 14.74 GiB memory in use. Of the allocated memory 14.57 GiB is allocated by PyTorch, and 37.21 MiB is reserved by PyTorch but unallocated. If reserved but unallocated memory is large try setting PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True to avoid fragmentation.  See documentation for Memory Management  (https://pytorch.org/docs/stable/notes/cuda.html#environment-variables)","traceback":["\u001b[0;31m---------------------------------------------------------------------------\u001b[0m","\u001b[0;31mOutOfMemoryError\u001b[0m                          Traceback (most recent ca